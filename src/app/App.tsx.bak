                  whileHover={{ scale: 1.04, y: -2 }}
                >
                  <div
                    className="absolute inset-0 opacity-0 group-hover:opacity-100 rounded-2xl transition-opacity duration-500 pointer-events-none"
                    style={{ background: "radial-gradient(circle at 50% 0%, rgba(79,142,247,0.1), transparent 70%)" }}
                  />
                  <div
                    className="text-2xl font-bold"
                    style={{ fontFamily: "'Plus Jakarta Sans', sans-serif", background: "linear-gradient(135deg,#4f8ef7,#00d4ff)", WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent", backgroundClip: "text" }}
                  >
                    {s.value}{s.suffix}
                  </div>
                  <div className="text-xs mt-1" style={{ color: isDark ? "rgba(232,238,255,0.4)" : "rgba(10,14,26,0.5)", fontFamily: "'Inter', sans-serif" }}>
                    {s.label}
                  </div>
                </motion.div>
              ))}
            </div>
          </motion.div>
        </div>
      </div>
    </Section>
  );
}

