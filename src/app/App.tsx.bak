// ─── Testimonials ─────────────────────────────────────────────────────────────
function Testimonials({ theme }: { theme: Theme }) {
  const isDark = theme === "dark";
  const g = glass[theme];
  const [current, setCurrent] = useState(0);

  useEffect(() => {
    const t = setInterval(() => setCurrent((c) => (c + 1) % TESTIMONIALS.length), 5200);
    return () => clearInterval(t);
  }, []);

  return (
    <Section id="testimonials" theme={theme}>
      <Orb color="#4f8ef7" size={400} x="40%" y="20%" delay={2} />
      <div className="max-w-4xl mx-auto">
        <SectionTitle label="// Reviews" title="What Clients Say" theme={theme} />
        <div className="relative">
          <AnimatePresence mode="wait">
            <motion.div
              key={current}
              className="p-8 md:p-12 rounded-3xl text-center relative overflow-hidden"
              style={g}
              initial={{ opacity: 0, y: 24, scale: 0.96, filter: "blur(8px)" }}
              animate={{ opacity: 1, y: 0, scale: 1, filter: "blur(0px)" }}
              exit={{ opacity: 0, y: -24, scale: 0.96, filter: "blur(8px)" }}
              transition={{ duration: 0.5 }}
            >
              <div
                className="absolute inset-0 pointer-events-none rounded-3xl"
                style={{ background: "radial-gradient(ellipse at 50% -20%, rgba(79,142,247,0.08), transparent 70%)" }}
              />
              <div className="flex justify-center mb-6">
                {[...Array(5)].map((_, i) => (
                  <motion.span key={i} className="text-yellow-400 text-xl" initial={{ opacity: 0, y: 8 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: i * 0.07 }}>
                    ★
                  </motion.span>
                ))}
              </div>
              <p className="text-lg md:text-xl leading-relaxed mb-8" style={{ color: isDark ? "rgba(232,238,255,0.85)" : "rgba(10,14,26,0.75)", fontFamily: "'Plus Jakarta Sans', sans-serif" }}>
                &ldquo;{TESTIMONIALS[current].text}&rdquo;
              </p>
              <div className="flex items-center justify-center gap-4">
                <img src={TESTIMONIALS[current].avatar} alt={TESTIMONIALS[current].name} className="w-12 h-12 rounded-full object-cover" style={{ border: "2px solid rgba(79,142,247,0.4)" }} />
                <div className="text-left">
                  <div className="font-bold text-sm" style={{ color: isDark ? "#e8eeff" : "#0a0e1a", fontFamily: "'Plus Jakarta Sans', sans-serif" }}>
                    {TESTIMONIALS[current].name}
                  </div>
                  <div className="text-xs" style={{ color: "#4f8ef7", fontFamily: "'Inter', sans-serif" }}>
                    {TESTIMONIALS[current].role}
                  </div>
                </div>
              </div>
            </motion.div>
          </AnimatePresence>
          <div className="flex justify-center gap-2 mt-6">
            {TESTIMONIALS.map((_, i) => (
              <motion.button
                key={i}
                onClick={() => setCurrent(i)}
                className="rounded-full cursor-pointer"
                style={{ height: 8, background: i === current ? "#4f8ef7" : "rgba(79,142,247,0.25)" }}
                animate={{ width: i === current ? 24 : 8 }}
                transition={{ duration: 0.3 }}
                data-hover
              />
            ))}
          </div>
        </div>
      </div>
    </Section>
  );
}

// ─── Contact ──────────────────────────────────────────────────────────────────
function Contact({ theme }: { theme: Theme }) {
  const isDark = theme === "dark";
  const g = glass[theme];
  const [form, setForm] = useState({ name: "", email: "", subject: "", message: "" });
  const [sending, setSending] = useState(false);
  const [sent, setSent] = useState(false);

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    setSending(true);
    setTimeout(() => { setSending(false); setSent(true); setTimeout(() => setSent(false), 3000); }, 1600);
  };

  const inputStyle: React.CSSProperties = {
    background: isDark ? "rgba(255,255,255,0.04)" : "rgba(255,255,255,0.75)",
    border: `1px solid ${isDark ? "rgba(255,255,255,0.08)" : "rgba(79,142,247,0.2)"}`,
    color: isDark ? "#e8eeff" : "#0a0e1a",
    fontFamily: "'Inter', sans-serif",
    outline: "none",
    borderRadius: "1rem",
    transition: "border-color 0.25s ease, box-shadow 0.25s ease",
    width: "100%",
    padding: "12px 16px",
    fontSize: "0.875rem",
  };

  return (
    <Section id="contact" theme={theme}>
      <Orb color="#7c3aed" size={400} x="-10%" y="50%" delay={2} />
      <Orb color="#00d4ff" size={350} x="75%" y="10%" delay={1} />
      <div className="max-w-5xl mx-auto">
        <SectionTitle label="// Connect" title="Let&apos;s Build Something" sub="Open to freelance projects, full-time roles, and creative collaborations." theme={theme} />
        <div className="grid md:grid-cols-2 gap-10">
          <motion.div
            className="space-y-5"
            initial={{ opacity: 0, x: -40, filter: "blur(8px)" }}
            whileInView={{ opacity: 1, x: 0, filter: "blur(0px)" }}
            viewport={{ once: true }}
            transition={{ duration: 0.8 }}
          >
            {[
              { icon: FiMail, label: "Email", value: "aniket@example.com", href: "mailto:aniket@example.com" },
              { icon: FiPhone, label: "Phone", value: "+91 98765 43210", href: "tel:+919876543210" },
              { icon: FiMapPin, label: "Location", value: "New Delhi, India", href: "#" },
            ].map(({ icon: Icon, label, value, href }) => (
              <motion.a
                key={label}
                href={href}
                className="flex items-center gap-4 p-4 rounded-2xl no-underline group"
                style={g}
                whileHover={{ scale: 1.02, x: 6 }}
                data-hover
              >
                <div className="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style={{ background: "rgba(79,142,247,0.12)", border: "1px solid rgba(79,142,247,0.25)" }}>
                  <Icon size={16} color="#4f8ef7" />
                </div>
                <div>
                  <div className="text-xs mb-0.5" style={{ color: isDark ? "rgba(232,238,255,0.4)" : "rgba(10,14,26,0.4)", fontFamily: "'Inter', sans-serif" }}>{label}</div>
                  <div className="text-sm font-medium" style={{ color: isDark ? "#e8eeff" : "#0a0e1a", fontFamily: "'Inter', sans-serif" }}>{value}</div>
                </div>
              </motion.a>
            ))}
            <div className="flex gap-3 pt-2">
              {[{ icon: FiGithub, label: "GitHub" }, { icon: FiLinkedin, label: "LinkedIn" }, { icon: FiTwitter, label: "Twitter" }, { icon: FiInstagram, label: "Instagram" }].map(({ icon: Icon, label }) => (
                <MagneticButton key={label} strength={0.4}>
                  <motion.a
                    href="#"
                    aria-label={label}
                    className="w-10 h-10 rounded-xl flex items-center justify-center"
                    style={g}
                    whileHover={{ scale: 1.15, y: -3, background: "rgba(79,142,247,0.15)" }}
                    whileTap={{ scale: 0.95 }}
                    data-hover
                  >
                    <Icon size={16} color={isDark ? "rgba(232,238,255,0.7)" : "rgba(10,14,26,0.6)"} />
                  </motion.a>
                </MagneticButton>
              ))}
            </div>
          </motion.div>

          <motion.form
            onSubmit={handleSubmit}
            className="space-y-4"
            initial={{ opacity: 0, x: 40, filter: "blur(8px)" }}
            whileInView={{ opacity: 1, x: 0, filter: "blur(0px)" }}
            viewport={{ once: true }}
            transition={{ duration: 0.8 }}
          >
            <div className="grid grid-cols-2 gap-4">
              <input placeholder="Your Name" value={form.name} onChange={(e) => setForm({ ...form, name: e.target.value })} style={inputStyle} required />
              <input type="email" placeholder="Email Address" value={form.email} onChange={(e) => setForm({ ...form, email: e.target.value })} style={inputStyle} required />
            </div>
            <input placeholder="Subject" value={form.subject} onChange={(e) => setForm({ ...form, subject: e.target.value })} style={inputStyle} />
            <textarea
              placeholder="Tell me about your project..."
              rows={5}
              value={form.message}
              onChange={(e) => setForm({ ...form, message: e.target.value })}
              style={{ ...inputStyle, resize: "none" }}
              required
            />
            <MagneticButton className="w-full" strength={0.15}>
              <motion.button
                type="submit"
                className="w-full py-3.5 rounded-2xl font-semibold text-white flex items-center justify-center gap-2"
                style={{
                  background: sent ? "linear-gradient(135deg, #10b981, #059669)" : "linear-gradient(135deg, #4f8ef7, #7c3aed)",
                  boxShadow: "0 4px 20px rgba(79,142,247,0.35)",
                  fontFamily: "'Inter', sans-serif",
                }}
                whileHover={{ scale: 1.02, boxShadow: "0 8px 28px rgba(79,142,247,0.5)" }}
                whileTap={{ scale: 0.98 }}
                disabled={sending}
                data-hover
              >
                <AnimatePresence mode="wait">
                  {sent ? (
                    <motion.span key="sent" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}>Message Sent ✓</motion.span>
                  ) : sending ? (
                    <motion.span key="sending" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="flex items-center gap-2">
                      <div className="w-4 h-4 rounded-full border-2 border-white/30 border-t-white animate-spin" />
                      Sending...
                    </motion.span>
                  ) : (
                    <motion.span key="idle" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="flex items-center gap-2">
                      Send Message <FiSend size={15} />
                    </motion.span>
                  )}
                </AnimatePresence>
              </motion.button>
            </MagneticButton>
          </motion.form>
        </div>
      </div>
    </Section>
  );
}

// ─── Footer ───────────────────────────────────────────────────────────────────
function Footer({ theme }: { theme: Theme }) {
  const isDark = theme === "dark";

  return (
    <footer
      className="relative py-12 px-6 overflow-hidden"
      style={{
        background: isDark ? "linear-gradient(180deg,#080d1e,#050816)" : "linear-gradient(180deg,#eef1ff,#e8f0ff)",
        borderTop: `1px solid ${isDark ? "rgba(79,142,247,0.1)" : "rgba(79,142,247,0.15)"}`,
      }}
    >
      <div className="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <AniketSVGLogo variant="nav" theme={theme} />
          <div className="text-xs mt-2" style={{ color: isDark ? "rgba(232,238,255,0.35)" : "rgba(10,14,26,0.4)", fontFamily: "'Inter', sans-serif" }}>
            Senior Frontend Developer & UI/UX Designer
          </div>
        </div>
        <div className="flex gap-3">
          {[FiGithub, FiLinkedin, FiTwitter, FiInstagram].map((Icon, i) => (
            <motion.a
              key={i} href="#"
              className="w-9 h-9 rounded-xl flex items-center justify-center"
              style={{ background: isDark ? "rgba(255,255,255,0.04)" : "rgba(79,142,247,0.08)", border: `1px solid ${isDark ? "rgba(255,255,255,0.07)" : "rgba(79,142,247,0.15)"}` }}
              whileHover={{ scale: 1.12, y: -2, background: "rgba(79,142,247,0.15)" }}
              whileTap={{ scale: 0.95 }}
              data-hover
            >
              <Icon size={15} color={isDark ? "rgba(232,238,255,0.6)" : "rgba(10,14,26,0.55)"} />
            </motion.a>
          ))}
        </div>
        <p className="text-xs" style={{ color: isDark ? "rgba(232,238,255,0.3)" : "rgba(10,14,26,0.4)", fontFamily: "'Inter', sans-serif" }}>
          © 2025 Aniket Tyagi. Crafted with precision.
        </p>
      </div>

      {/* Back to top */}
      <MagneticButton className="fixed bottom-6 right-6 z-50" strength={0.5}>
        <motion.button
          onClick={() => window.scrollTo({ top: 0, behavior: "smooth" })}
          className="w-11 h-11 rounded-2xl flex items-center justify-center"
          style={{ background: "linear-gradient(135deg,#4f8ef7,#7c3aed)", boxShadow: "0 4px 20px rgba(79,142,247,0.5)" }}
          whileHover={{ scale: 1.12, y: -2 }}
          whileTap={{ scale: 0.95 }}
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 2 }}
          aria-label="Back to top"
          data-hover
        >
          <FiArrowUp size={16} color="white" />
        </motion.button>
      </MagneticButton>
    </footer>
  );
}

// ─── Wave Transition Overlay ──────────────────────────────────────────────────
// Renders as a portal-like fixed div; wave is driven imperatively via ref
function WaveOverlay({ waveRef }: { waveRef: React.RefObject<HTMLDivElement> }) {
  return (
    <div
      ref={waveRef}
      className="fixed inset-0 z-[9990] pointer-events-none"
      style={{ display: "none" }}
    />
  );
}

// ─── App ──────────────────────────────────────────────────────────────────────
export default function App() {
  const [loaded, setLoaded] = useState(false);
  const [theme, setTheme] = useState<Theme>(() => {
    try {
      return (localStorage.getItem("portfolio-theme") as Theme) ?? "dark";
    } catch {
      return "dark";
    }
  });

  const waveRef = useRef<HTMLDivElement>(null);

  // Apply dark class + global styles
  useEffect(() => {
    const root = document.documentElement;
    root.classList.toggle("dark", theme === "dark");
    document.body.style.fontFamily = "'Inter', sans-serif";
    document.body.style.overflowX = "hidden";
    // Hide default cursor
    document.body.style.cursor = "none";
  }, [theme]);

  // Cinematic wave theme toggle
  const toggleTheme = useCallback(
    (e: React.MouseEvent) => {
      const newTheme = theme === "dark" ? "light" : "dark";
      const wave = waveRef.current;
      if (!wave) {
        setTheme(newTheme);
        localStorage.setItem("portfolio-theme", newTheme);
        return;
      }

      const x = e.clientX;
      const y = e.clientY;
      const maxR =
        Math.max(
          Math.hypot(x, y),
          Math.hypot(window.innerWidth - x, y),
          Math.hypot(x, window.innerHeight - y),
          Math.hypot(window.innerWidth - x, window.innerHeight - y)
        ) * 1.05;

      wave.style.display = "block";
      wave.style.background = newTheme === "dark" ? "#050816" : "#f0f4ff";
      wave.style.clipPath = `circle(0px at ${x}px ${y}px)`;
      wave.style.transition = "none";

      // Double RAF for reliable paint before transition
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          wave.style.transition = "clip-path 0.92s cubic-bezier(0.65, 0, 0.35, 1)";
          wave.style.clipPath = `circle(${maxR}px at ${x}px ${y}px)`;
        });
      });

      setTimeout(() => {
        setTheme(newTheme);
        localStorage.setItem("portfolio-theme", newTheme);
        requestAnimationFrame(() => {
          wave.style.display = "none";
          wave.style.transition = "";
          wave.style.clipPath = "";
        });
      }, 880);
    },
    [theme]
  );

  const isDark = theme === "dark";

  return (
    <div
      className="min-h-screen"
      style={{
        background: isDark ? "#050816" : "#f0f4ff",
        color: isDark ? "#e8eeff" : "#0a0e1a",
      }}
    >
      {/* Loading screen */}
      <AnimatePresence>{!loaded && <LoadingScreen onComplete={() => setLoaded(true)} />}</AnimatePresence>

      {/* Wave transition overlay */}
      <WaveOverlay waveRef={waveRef as React.RefObject<HTMLDivElement>} />

      {/* Custom cursor */}
      <CustomCursor theme={theme} />

      {/* Scroll progress */}
      <ScrollProgress />

      {/* Main content */}
      <AnimatePresence>
        {loaded && (
          <motion.div
            key="main"
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            transition={{ duration: 0.6 }}
          >
            <Navbar theme={theme} onToggleTheme={toggleTheme} />
            <Hero theme={theme} />
            <About theme={theme} />
            <Experience theme={theme} />
            <Skills theme={theme} />
            <Projects theme={theme} />
            <Services theme={theme} />
            <Testimonials theme={theme} />
            <Contact theme={theme} />
            <Footer theme={theme} />
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
