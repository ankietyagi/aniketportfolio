}

// ─── Projects ─────────────────────────────────────────────────────────────────
function Projects({ theme }: { theme: Theme }) {
  const isDark = theme === "dark";
  const g = glass[theme];
  const [hovered, setHovered] = useState<number | null>(null);
  const cardRefs = useRef<(HTMLDivElement | null)[]>([]);
  const [tilts, setTilts] = useState<{ x: number; y: number }[]>(PROJECTS.map(() => ({ x: 0, y: 0 })));

  const handleCardMove = (e: React.MouseEvent, i: number) => {
    const card = cardRefs.current[i];
    if (!card) return;
    const rect = card.getBoundingClientRect();
    const x = (e.clientX - rect.left) / rect.width - 0.5;
    const y = (e.clientY - rect.top) / rect.height - 0.5;
    setTilts((t) => t.map((v, idx) => (idx === i ? { x: y * -10, y: x * 10 } : v)));
  };

  const resetTilt = (i: number) => {
    setTilts((t) => t.map((v, idx) => (idx === i ? { x: 0, y: 0 } : v)));
  };

  return (
    <Section id="projects" theme={theme}>
      <Orb color="#7c3aed" size={450} x="-5%" y="30%" delay={3} />
      <div className="max-w-6xl mx-auto">
        <SectionTitle label="// Portfolio" title="Featured Projects" sub="A selection of work I'm proud of — shipped and live." theme={theme} />
        <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {PROJECTS.map((project, i) => (
            <motion.div
              key={i}
              ref={(el) => { cardRefs.current[i] = el; }}
              className="relative rounded-3xl overflow-hidden cursor-pointer group"
              style={{
                ...g,
                transform: `perspective(800px) rotateX(${tilts[i].x}deg) rotateY(${tilts[i].y}deg)`,
                transition: "transform 0.15s ease-out, box-shadow 0.3s ease",
              }}
              initial={{ opacity: 0, y: 50, filter: "blur(8px)" }}
              whileInView={{ opacity: 1, y: 0, filter: "blur(0px)" }}
              viewport={{ once: true, margin: "-60px" }}
              transition={{ duration: 0.7, delay: i * 0.08 }}
              onHoverStart={() => setHovered(i)}
              onHoverEnd={() => { setHovered(null); resetTilt(i); }}
              onMouseMove={(e) => handleCardMove(e, i)}
              onMouseLeave={() => resetTilt(i)}
              whileHover={{ y: -8, boxShadow: "0 24px 56px rgba(79,142,247,0.2), 0 0 0 1px rgba(79,142,247,0.3)" }}
              data-hover
            >
              <div className="relative h-48 overflow-hidden bg-slate-900">
                <motion.img
                  src={project.image}
                  alt={project.title}
                  className="w-full h-full object-cover"
                  animate={{ scale: hovered === i ? 1.08 : 1 }}
                  transition={{ duration: 0.5 }}
                />
                <div
                  className="absolute inset-0"
                  style={{
                    background: isDark
                      ? "linear-gradient(to bottom, transparent 35%, rgba(5,8,22,0.97))"
                      : "linear-gradient(to bottom, transparent 35%, rgba(240,244,255,0.97))",
                  }}
                />
                {/* Hover links */}
                <motion.div
                  className="absolute top-3 right-3 flex gap-2"
                  initial={{ opacity: 0, y: -8 }}
                  animate={{ opacity: hovered === i ? 1 : 0, y: hovered === i ? 0 : -8 }}
                  transition={{ duration: 0.2 }}
                >
                  <a href={project.live} className="w-8 h-8 rounded-xl flex items-center justify-center" style={{ background: "rgba(79,142,247,0.9)" }} onClick={(e) => e.stopPropagation()}>
                    <FiExternalLink size={13} color="white" />
                  </a>
                  <a href={project.github} className="w-8 h-8 rounded-xl flex items-center justify-center" style={{ background: "rgba(0,0,0,0.4)", backdropFilter: "blur(8px)" }} onClick={(e) => e.stopPropagation()}>
                    <FiGithub size={13} color="white" />
                  </a>
                </motion.div>
                {/* Glow on hover */}
                <motion.div
                  className="absolute inset-0 pointer-events-none"
                  style={{ background: "radial-gradient(circle at 50% 50%, rgba(79,142,247,0.12), transparent 70%)" }}
                  animate={{ opacity: hovered === i ? 1 : 0 }}
                  transition={{ duration: 0.3 }}
                />
              </div>
              <div className="p-5">
                <h3 className="font-bold text-base mb-2" style={{ fontFamily: "'Plus Jakarta Sans', sans-serif", color: isDark ? "#e8eeff" : "#0a0e1a" }}>
                  {project.title}
                </h3>
                <p className="text-xs leading-relaxed mb-4" style={{ color: isDark ? "rgba(232,238,255,0.5)" : "rgba(10,14,26,0.55)", fontFamily: "'Inter', sans-serif" }}>
                  {project.desc}
                </p>
                <div className="flex flex-wrap gap-1.5">
                  {project.tags.map((tag) => (
                    <span
                      key={tag}
                      className="text-xs px-2 py-0.5 rounded-lg"
                      style={{ background: "rgba(79,142,247,0.1)", color: "#4f8ef7", fontFamily: "'JetBrains Mono', monospace", border: "1px solid rgba(79,142,247,0.2)" }}
                    >
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </motion.div>
          ))}
        </div>
      </div>
    </Section>
  );
}

