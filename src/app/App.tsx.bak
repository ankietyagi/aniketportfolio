              </motion.div>
            );
          })}
        </div>

        {/* Marquee */}
        <div className="relative overflow-hidden py-4">
          <div className="absolute left-0 top-0 bottom-0 w-20 z-10 pointer-events-none" style={{ background: `linear-gradient(90deg, ${isDark ? "#050816" : "#f0f4ff"}, transparent)` }} />
          <div className="absolute right-0 top-0 bottom-0 w-20 z-10 pointer-events-none" style={{ background: `linear-gradient(-90deg, ${isDark ? "#050816" : "#f0f4ff"}, transparent)` }} />
          <motion.div
            className="flex gap-3 w-max"
            animate={{ x: [0, -1400] }}
            transition={{ duration: 28, repeat: Infinity, ease: "linear" }}
          >
            {[...MARQUEE_TECHS, ...MARQUEE_TECHS].map((tech, i) => (
              <motion.span
