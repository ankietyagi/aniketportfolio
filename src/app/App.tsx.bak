                </p>
                <div
                  className="absolute -bottom-10 -right-10 w-36 h-36 rounded-full pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                  style={{ background: `radial-gradient(circle, ${svc.color}22, transparent 70%)`, filter: "blur(20px)" }}
                />
