// ─── Typing effect hook ───────────────────────────────────────────────────────
function useTypingEffect(words: string[], speed = 80, pause = 1800) {
  const [display, setDisplay] = useState("");
  const [wordIndex, setWordIndex] = useState(0);
  const [charIndex, setCharIndex] = useState(0);
  const [deleting, setDeleting] = useState(false);

  useEffect(() => {
    const current = words[wordIndex];
    let timeout: ReturnType<typeof setTimeout>;
    if (!deleting) {
      if (charIndex < current.length) {
        timeout = setTimeout(() => setCharIndex((c) => c + 1), speed);
      } else {
        timeout = setTimeout(() => setDeleting(true), pause);
      }
    } else {
      if (charIndex > 0) {
        timeout = setTimeout(() => setCharIndex((c) => c - 1), speed / 2);
      } else {
        setDeleting(false);
        setWordIndex((w) => (w + 1) % words.length);
      }
    }
    setDisplay(current.slice(0, charIndex));
    return () => clearTimeout(timeout);
  }, [charIndex, deleting, wordIndex, words, speed, pause]);

  return display;
}

// ─── ANIKET SVG Logo with code particles ─────────────────────────────────────
function AniketSVGLogo({
  variant = "full",
  theme = "dark",
}: {
  variant?: "full" | "nav" | "loading";
  theme?: Theme;
}) {
  const isDark = theme === "dark";
  const id = `logo-${variant}`;

  const particles = useMemo(
    () =>
      Array.from({ length: variant === "nav" ? 18 : 55 }, (_, i) => ({
        id: i,
        x: 20 + Math.random() * 860,
        y: 20 + Math.random() * 160,
        symbol: CODE_SYMBOLS[i % CODE_SYMBOLS.length],
        fontSize: variant === "nav" ? Math.random() * 6 + 5 : Math.random() * 10 + 7,
        opacity: Math.random() * 0.55 + 0.2,
        duration: Math.random() * 12 + 8,
        delay: Math.random() * 8,
        dx: (Math.random() - 0.5) * 160,
        dy: (Math.random() - 0.5) * 100,
      })),
    [variant]
  );

  const width =
    variant === "loading" ? "min(580px, 85vw)" : variant === "full" ? "min(520px, 85vw)" : "100px";

  return (
    <div
      style={{
        filter: `drop-shadow(0 0 ${variant === "nav" ? 12 : 30}px rgba(79,142,247,${isDark ? 0.5 : 0.35}))`,
        display: "inline-flex",
      }}
    >
      <svg viewBox="0 0 900 200" style={{ width, height: "auto" }} overflow="visible">
        <defs>
          <clipPath id={`clip-${id}`}>
            <text
              x="0" y="170"
              fontSize="162"
              fontWeight="800"
              fontFamily="'Plus Jakarta Sans', sans-serif"
              textLength="900"
              lengthAdjust="spacingAndGlyphs"
            >
              ANIKET
            </text>
          </clipPath>

          <linearGradient id={`grad-${id}`} x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stopColor="#4f8ef7" stopOpacity="0.95" />
            <stop offset="45%" stopColor="#7c3aed" stopOpacity="0.8" />
            <stop offset="100%" stopColor="#00d4ff" stopOpacity="0.9" />
          </linearGradient>

          <linearGradient id={`shine-${id}`} x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stopColor="white" stopOpacity="0.45" />
            <stop offset="35%" stopColor="white" stopOpacity="0.08" />
            <stop offset="100%" stopColor="white" stopOpacity="0.0" />
          </linearGradient>

          <radialGradient id={`inner-${id}`} cx="40%" cy="40%" r="65%">
            <stop offset="0%" stopColor="#00d4ff" stopOpacity="0.25" />
            <stop offset="100%" stopColor="#4f8ef7" stopOpacity="0.02" />
          </radialGradient>
        </defs>

        {/* Base letter fill – gradient */}
        <rect x="0" y="0" width="900" height="200" fill={`url(#grad-${id})`} clipPath={`url(#clip-${id})`} />

        {/* Inner radial glow */}
        <rect x="0" y="0" width="900" height="200" fill={`url(#inner-${id})`} clipPath={`url(#clip-${id})`} />

        {/* Floating code particles inside letters */}
        {particles.map((p) => (
          <motion.text
            key={p.id}
            x={p.x}
            y={p.y}
            fontSize={p.fontSize}
            fontFamily="'JetBrains Mono', monospace"
            fontWeight="500"
            fill="white"
            fillOpacity={p.opacity}
            clipPath={`url(#clip-${id})`}
            animate={{
              x: [p.x, p.x + p.dx, p.x - p.dx * 0.6, p.x + p.dx * 0.3, p.x],
              y: [p.y, p.y + p.dy, p.y - p.dy * 0.8, p.y + p.dy * 0.4, p.y],
              fillOpacity: [p.opacity, Math.min(p.opacity * 1.8, 0.9), p.opacity * 0.4, p.opacity * 1.2, p.opacity],
            }}
            transition={{
              duration: p.duration,
              repeat: Infinity,
              delay: p.delay,
              ease: "easeInOut",
            }}
          >
            {p.symbol}
          </motion.text>
        ))}

        {/* Glass top-shine */}
        <rect x="0" y="0" width="900" height="200" fill={`url(#shine-${id})`} clipPath={`url(#clip-${id})`} />

        {/* Sweep shine sweep */}
        <motion.rect
          x="-250" y="0" width="220" height="200"
          fill="rgba(255,255,255,0.22)"
          clipPath={`url(#clip-${id})`}
          style={{ filter: "blur(10px)" }}
          animate={{ x: [-250, 1150] }}
          transition={{ duration: 3.5, repeat: Infinity, repeatDelay: 4.5, ease: "easeInOut" }}
        />

        {/* Letter edge stroke */}
        <text
          x="0" y="170"
          fontSize="162"
          fontWeight="800"
          fontFamily="'Plus Jakarta Sans', sans-serif"
          textLength="900"
          lengthAdjust="spacingAndGlyphs"
          fill="none"
          stroke={isDark ? "rgba(255,255,255,0.12)" : "rgba(79,142,247,0.25)"}
          strokeWidth="0.8"
        >
          ANIKET
        </text>

        {/* Breathing neon glow stroke */}
        <motion.text
          x="0" y="170"
          fontSize="162"
          fontWeight="800"
          fontFamily="'Plus Jakarta Sans', sans-serif"
          textLength="900"
          lengthAdjust="spacingAndGlyphs"
          fill="none"
          stroke="rgba(79,142,247,0.5)"
          strokeWidth="1.5"
          style={{ filter: "blur(4px)" }}
          animate={{ opacity: [0.3, 0.9, 0.3] }}
          transition={{ duration: 3.2, repeat: Infinity, ease: "easeInOut" }}
        >
          ANIKET
        </motion.text>
      </svg>
    </div>
  );
}

// ─── Custom Cursor ────────────────────────────────────────────────────────────
function CustomCursor({ theme }: { theme: Theme }) {
  const outerRef = useRef<HTMLDivElement>(null);
  const dotRef = useRef<HTMLDivElement>(null);
  const trailRef = useRef<HTMLDivElement[]>([]);
  const [cursorState, setCursorState] = useState<"default" | "hover" | "click">("default");
  const posRef = useRef({ x: -200, y: -200 });
  const currentRef = useRef({ x: -200, y: -200 });

  useEffect(() => {
    const handleMove = (e: MouseEvent) => {
      posRef.current = { x: e.clientX, y: e.clientY };
      // Update CSS var for cursor-follow glow
      document.documentElement.style.setProperty("--cx", `${e.clientX}px`);
      document.documentElement.style.setProperty("--cy", `${e.clientY}px`);
    };
    const handleDown = () => setCursorState("click");
    const handleUp = () => setCursorState((s) => (s === "click" ? "default" : s));

    const onEnter = () => setCursorState("hover");
    const onLeave = () => setCursorState("default");

    const observe = () => {
      document.querySelectorAll("a, button, [data-hover]").forEach((el) => {
        el.addEventListener("mouseenter", onEnter);
        el.addEventListener("mouseleave", onLeave);
      });
    };

    window.addEventListener("mousemove", handleMove);
    window.addEventListener("mousedown", handleDown);
    window.addEventListener("mouseup", handleUp);
    observe();

    let raf: number;
    const animate = () => {
      const lerp = cursorState === "hover" ? 0.1 : 0.14;
      currentRef.current.x += (posRef.current.x - currentRef.current.x) * lerp;
      currentRef.current.y += (posRef.current.y - currentRef.current.y) * lerp;

      const outer = outerRef.current;
      const dot = dotRef.current;
      const size = cursorState === "hover" ? 52 : cursorState === "click" ? 24 : 40;

      if (outer) {
        outer.style.transform = `translate(${currentRef.current.x - size / 2}px, ${currentRef.current.y - size / 2}px)`;
        outer.style.width = `${size}px`;
        outer.style.height = `${size}px`;
      }
      if (dot) {
        dot.style.transform = `translate(${posRef.current.x - 4}px, ${posRef.current.y - 4}px)`;
      }

      raf = requestAnimationFrame(animate);
    };
    animate();

    return () => {
      window.removeEventListener("mousemove", handleMove);
      window.removeEventListener("mousedown", handleDown);
      window.removeEventListener("mouseup", handleUp);
      cancelAnimationFrame(raf);
    };
  }, [cursorState]);

  const isDark = theme === "dark";

  return (
    <>
      {/* Outer ring */}
      <div
        ref={outerRef}
        className="fixed top-0 left-0 pointer-events-none z-[9997] rounded-full"
        style={{
          width: 40, height: 40,
          background:
            cursorState === "hover"
              ? "rgba(79,142,247,0.12)"
              : "rgba(79,142,247,0.06)",
          border: `1px solid rgba(79,142,247,${cursorState === "hover" ? 0.6 : 0.35})`,
          backdropFilter: "blur(4px)",
          boxShadow: `0 0 ${cursorState === "hover" ? 24 : 12}px rgba(79,142,247,${cursorState === "hover" ? 0.4 : 0.2})`,
          transition: "width 0.25s cubic-bezier(0.34,1.56,0.64,1), height 0.25s cubic-bezier(0.34,1.56,0.64,1), background 0.3s ease, box-shadow 0.3s ease",
          willChange: "transform",
        }}
      />
      {/* Center dot */}
      <div
        ref={dotRef}
        className="fixed top-0 left-0 pointer-events-none z-[9998] rounded-full"
        style={{
          width: 8, height: 8,
          background: "#4f8ef7",
          boxShadow: "0 0 10px rgba(79,142,247,0.9), 0 0 4px rgba(0,212,255,0.5)",
          willChange: "transform",
        }}
      />
      {/* Click ripple */}
      <AnimatePresence>
        {cursorState === "click" && (
          <motion.div
            className="fixed top-0 left-0 pointer-events-none z-[9996] rounded-full"
            style={{
              width: 60, height: 60,
              marginLeft: -30, marginTop: -30,
              border: "1px solid rgba(79,142,247,0.6)",
              x: posRef.current.x,
              y: posRef.current.y,
            }}
            initial={{ scale: 0.3, opacity: 0.8 }}
            animate={{ scale: 2.5, opacity: 0 }}
            exit={{ opacity: 0 }}
            transition={{ duration: 0.6, ease: "easeOut" }}
          />
        )}
      </AnimatePresence>
    </>
  );
}

// ─── Loading Screen ───────────────────────────────────────────────────────────
function LoadingScreen({ onComplete }: { onComplete: () => void }) {
  const [progress, setProgress] = useState(0);
  const [done, setDone] = useState(false);

  useEffect(() => {
    let p = 0;
    const interval = setInterval(() => {
      p += Math.random() * 2.8 + 0.8;
      if (p >= 100) {
        p = 100;
        clearInterval(interval);
        setTimeout(() => {
          setDone(true);
          setTimeout(onComplete, 700);
        }, 300);
      }
      setProgress(Math.floor(Math.min(p, 100)));
    }, 40);
    return () => clearInterval(interval);
  }, [onComplete]);

  return (
    <AnimatePresence>
      {!done ? (
        <motion.div
          className="fixed inset-0 z-[9999] flex flex-col items-center justify-center"
          style={{ background: "#050816" }}
          exit={{ opacity: 0, scale: 1.04 }}
          transition={{ duration: 0.7, ease: [0.16, 1, 0.3, 1] }}
        >
          {/* Background orbs */}
          <div className="absolute inset-0 pointer-events-none overflow-hidden">
            <motion.div
              className="absolute rounded-full"
              style={{ width: 500, height: 500, left: "10%", top: "20%", background: "radial-gradient(circle, rgba(79,142,247,0.18) 0%, transparent 70%)", filter: "blur(60px)" }}
              animate={{ x: [0, 30, 0], y: [0, -20, 0] }}
              transition={{ duration: 10, repeat: Infinity, ease: "easeInOut" }}
            />
            <motion.div
              className="absolute rounded-full"
              style={{ width: 400, height: 400, right: "10%", bottom: "20%", background: "radial-gradient(circle, rgba(124,58,237,0.18) 0%, transparent 70%)", filter: "blur(60px)" }}
              animate={{ x: [0, -30, 0], y: [0, 20, 0] }}
              transition={{ duration: 12, repeat: Infinity, ease: "easeInOut" }}
            />
          </div>

          {/* Logo */}
          <motion.div
            initial={{ opacity: 0, y: 30, scale: 0.9 }}
            animate={{ opacity: 1, y: 0, scale: 1 }}
            transition={{ duration: 0.9, ease: [0.16, 1, 0.3, 1] }}
          >
            <AniketSVGLogo variant="loading" theme="dark" />
          </motion.div>

          {/* Tagline */}
          <motion.p
            className="mt-8 text-sm tracking-widest uppercase"
            style={{ color: "rgba(79,142,247,0.6)", fontFamily: "'JetBrains Mono', monospace" }}
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            transition={{ delay: 0.5 }}
          >
            Frontend Developer & UI/UX Designer
          </motion.p>

          {/* Progress bar */}
          <motion.div
            className="mt-12 w-72"
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            transition={{ delay: 0.6 }}
          >
            <div className="flex justify-between mb-2">
              <span className="text-xs" style={{ color: "rgba(232,238,255,0.3)", fontFamily: "'JetBrains Mono', monospace" }}>
                Loading
              </span>
              <span className="text-xs" style={{ color: "#4f8ef7", fontFamily: "'JetBrains Mono', monospace" }}>
                {progress}%
              </span>
            </div>
            <div className="h-px rounded-full overflow-hidden" style={{ background: "rgba(79,142,247,0.15)" }}>
              <motion.div
                className="h-full rounded-full"
                style={{ background: "linear-gradient(90deg, #4f8ef7, #7c3aed, #00d4ff)", width: `${progress}%` }}
                transition={{ duration: 0.1 }}
              />
            </div>
          </motion.div>
        </motion.div>
      ) : null}
    </AnimatePresence>
  );
}

// ─── Magnetic Button ──────────────────────────────────────────────────────────
function MagneticButton({
  children,
  strength = 0.28,
  className = "",
  style: styleProp = {},
  onClick,
  as: Tag = "div",
}: {
  children: React.ReactNode;
  strength?: number;
  className?: string;
  style?: React.CSSProperties;
  onClick?: (e: React.MouseEvent) => void;
  as?: keyof JSX.IntrinsicElements | "div";
}) {
  const ref = useRef<HTMLDivElement>(null);
  const [offset, setOffset] = useState({ x: 0, y: 0 });

  const onMove = useCallback((e: React.MouseEvent) => {
    if (!ref.current) return;
    const rect = ref.current.getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top + rect.height / 2;
    setOffset({ x: (e.clientX - cx) * strength, y: (e.clientY - cy) * strength });
  }, [strength]);

  const onLeave = useCallback(() => setOffset({ x: 0, y: 0 }), []);

  return (
    <motion.div
      ref={ref}
      className={className}
      style={styleProp}
      onMouseMove={onMove}
      onMouseLeave={onLeave}
      animate={{ x: offset.x, y: offset.y }}
      transition={{ type: "spring", stiffness: 280, damping: 20 }}
      onClick={onClick}
    >
      {children}
    </motion.div>
  );
}

// ─── Floating Orb ────────────────────────────────────────────────────────────
function Orb({ color, size, x, y, delay = 0 }: { color: string; size: number; x: string; y: string; delay?: number }) {
  return (
    <motion.div
      className="absolute rounded-full pointer-events-none"
      style={{
        width: size, height: size, left: x, top: y,
        background: `radial-gradient(circle at 40% 40%, ${color}55, ${color}18, transparent 70%)`,
        filter: "blur(60px)",
      }}
      animate={{ x: [0, 35, -25, 15, 0], y: [0, -25, 35, -10, 0], scale: [1, 1.12, 0.94, 1.06, 1] }}
      transition={{ duration: 14 + delay, repeat: Infinity, ease: "easeInOut", delay }}
    />
  );
}

// ─── Particles ───────────────────────────────────────────────────────────────
function Particles({ theme }: { theme: Theme }) {
  const items = useMemo(
    () =>
      Array.from({ length: 38 }, (_, i) => ({
        id: i,
        left: `${Math.random() * 100}%`,
        top: `${Math.random() * 100}%`,
        size: Math.random() * 2.5 + 1,
        dur: Math.random() * 5 + 4,
        delay: Math.random() * 7,
      })),
    []
  );
  return (
    <div className="absolute inset-0 overflow-hidden pointer-events-none">
      {items.map((p) => (
        <motion.div
          key={p.id}
          className="absolute rounded-full"
          style={{
            width: p.size, height: p.size, left: p.left, top: p.top,
            background: theme === "dark" ? "rgba(79,142,247,0.65)" : "rgba(79,142,247,0.45)",
          }}
          animate={{ y: [0, -70, 0], opacity: [0, 1, 0] }}
          transition={{ duration: p.dur, repeat: Infinity, delay: p.delay, ease: "easeInOut" }}
        />
      ))}
    </div>
  );
}

// ─── Section wrapper + title ─────────────────────────────────────────────────
function Section({ id, children, theme }: { id: string; children: React.ReactNode; theme: Theme }) {
  return (
    <section
      id={id}
      className="relative py-24 px-6 overflow-hidden"
      style={{
        background:
          theme === "dark"
            ? "linear-gradient(180deg, #050816 0%, #080d1e 100%)"
            : "linear-gradient(180deg, #f0f4ff 0%, #eef1ff 100%)",
      }}
    >
      {children}
    </section>
  );
}

function SectionTitle({ label, title, sub, theme }: { label: string; title: string; sub?: string; theme: Theme }) {
  const isDark = theme === "dark";
  return (
    <motion.div
      className="text-center mb-16"
      initial={{ opacity: 0, y: 30, filter: "blur(8px)" }}
      whileInView={{ opacity: 1, y: 0, filter: "blur(0px)" }}
      viewport={{ once: true, margin: "-80px" }}
      transition={{ duration: 0.8 }}
    >
      <div
        className="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold tracking-widest uppercase mb-4"
        style={{ background: "rgba(79,142,247,0.12)", color: "#4f8ef7", fontFamily: "'JetBrains Mono', monospace" }}
      >
        {label}
      </div>
      <h2
        className="text-4xl md:text-5xl font-bold leading-tight"
        style={{ fontFamily: "'Plus Jakarta Sans', sans-serif", color: isDark ? "#e8eeff" : "#0a0e1a" }}
      >
        {title}
      </h2>
      {sub && (
        <p className="mt-4 text-base max-w-xl mx-auto" style={{ color: isDark ? "rgba(232,238,255,0.5)" : "rgba(10,14,26,0.5)", fontFamily: "'Inter', sans-serif" }}>
          {sub}
        </p>
      )}
    </motion.div>
  );
}

// ─── Premium Theme Toggle ─────────────────────────────────────────────────────
function PremiumToggle({ theme, onToggle }: { theme: Theme; onToggle: (e: React.MouseEvent) => void }) {
  const isDark = theme === "dark";
  const knobRef = useRef<HTMLButtonElement>(null);

  return (
    <motion.button
      ref={knobRef}
      onClick={onToggle}
      className="relative flex items-center cursor-pointer select-none"
      style={{
        width: 58,
        height: 30,
        borderRadius: 30,
        background: isDark
          ? "linear-gradient(135deg, rgba(79,142,247,0.2), rgba(124,58,237,0.15))"
          : "linear-gradient(135deg, rgba(255,200,80,0.25), rgba(255,140,0,0.15))",
        border: isDark ? "1px solid rgba(79,142,247,0.35)" : "1px solid rgba(255,160,40,0.4)",
        boxShadow: isDark
          ? "0 2px 12px rgba(79,142,247,0.25), inset 0 1px 0 rgba(255,255,255,0.08)"
          : "0 2px 12px rgba(255,160,40,0.2), inset 0 1px 0 rgba(255,255,255,0.6)",
        padding: "2px 3px",
      }}
      aria-label="Toggle theme"
      whileTap={{ scale: 0.94 }}
    >
      {/* Ripple on toggle */}
      <motion.div
        className="absolute inset-0 rounded-full pointer-events-none"
        style={{ border: isDark ? "1px solid rgba(79,142,247,0.5)" : "1px solid rgba(255,160,40,0.5)" }}
        animate={{ scale: [1, 1.3, 1], opacity: [0.6, 0, 0] }}
        transition={{ duration: 0.6, ease: "easeOut" }}
        key={theme}
      />

      {/* Knob */}
      <motion.div
        className="relative flex items-center justify-center rounded-full z-10"
        style={{
          width: 24, height: 24,
          background: isDark
            ? "linear-gradient(135deg, #4f8ef7 0%, #7c3aed 100%)"
            : "linear-gradient(135deg, #f59e0b 0%, #f97316 100%)",
          boxShadow: isDark
            ? "0 2px 10px rgba(79,142,247,0.7), inset 0 1px 0 rgba(255,255,255,0.3)"
            : "0 2px 10px rgba(245,158,11,0.6), inset 0 1px 0 rgba(255,255,255,0.5)",
        }}
        animate={{ x: isDark ? 0 : 28 }}
        transition={{ type: "spring", stiffness: 400, damping: 25, mass: 0.8 }}
      >
        {/* Icon morph */}
        <AnimatePresence mode="wait">
          {isDark ? (
            <motion.div
              key="moon"
              initial={{ rotate: -120, scale: 0, opacity: 0 }}
              animate={{ rotate: 0, scale: 1, opacity: 1 }}
              exit={{ rotate: 120, scale: 0, opacity: 0 }}
              transition={{ duration: 0.25 }}
            >
              <FiMoon size={13} color="white" />
            </motion.div>
          ) : (
            <motion.div
              key="sun"
              initial={{ rotate: 120, scale: 0, opacity: 0 }}
              animate={{ rotate: 0, scale: 1, opacity: 1 }}
              exit={{ rotate: -120, scale: 0, opacity: 0 }}
              transition={{ duration: 0.25 }}
            >
              <FiSun size={13} color="white" />
            </motion.div>
          )}
        </AnimatePresence>
      </motion.div>

      {/* Track icons */}
      <div className="absolute left-2.5 top-1/2 -translate-y-1/2" style={{ opacity: isDark ? 0.4 : 0 }}>
        <FiMoon size={9} color="rgba(79,142,247,0.8)" />
      </div>
      <div className="absolute right-2.5 top-1/2 -translate-y-1/2" style={{ opacity: isDark ? 0 : 0.4 }}>
        <FiSun size={9} color="rgba(245,158,11,0.8)" />
      </div>
    </motion.button>
  );
}

// ─── Navbar ───────────────────────────────────────────────────────────────────
function Navbar({ theme, onToggleTheme }: { theme: Theme; onToggleTheme: (e: React.MouseEvent) => void }) {
  const [scrolled, setScrolled] = useState(false);
  const [active, setActive] = useState("Home");
  const [menuOpen, setMenuOpen] = useState(false);

  useEffect(() => {
    const s = () => setScrolled(window.scrollY > 40);
    window.addEventListener("scroll", s, { passive: true });
    return () => window.removeEventListener("scroll", s);
  }, []);

  const scrollTo = (id: string) => {
    document.getElementById(id.toLowerCase())?.scrollIntoView({ behavior: "smooth" });
    setActive(id);
    setMenuOpen(false);
  };

  const isDark = theme === "dark";

  return (
    <motion.nav
      className="fixed top-0 left-0 right-0 z-50 flex justify-center pt-4 px-4"
      initial={{ y: -80, opacity: 0 }}
      animate={{ y: 0, opacity: 1 }}
      transition={{ duration: 0.8, ease: [0.16, 1, 0.3, 1] }}
    >
      <motion.div
        className="flex items-center justify-between w-full max-w-6xl rounded-2xl px-5 py-3"
        style={scrolled ? navGlass[theme] : { background: "transparent", border: "1px solid transparent" }}
        animate={{ scale: scrolled ? 0.98 : 1 }}
        transition={{ duration: 0.3 }}
      >
        {/* Logo */}
        <motion.div className="cursor-pointer" whileHover={{ scale: 1.04 }} onClick={() => scrollTo("home")}>
          <AniketSVGLogo variant="nav" theme={theme} />
        </motion.div>

        {/* Desktop nav */}
        <div className="hidden md:flex items-center gap-0.5">
          {NAV_LINKS.map((link) => (
            <motion.button
              key={link}
              onClick={() => scrollTo(link)}
              className="relative px-3.5 py-2 text-sm font-medium rounded-xl"
              style={{
                fontFamily: "'Inter', sans-serif",
                color: active === link ? "#4f8ef7" : isDark ? "rgba(232,238,255,0.65)" : "rgba(10,14,26,0.6)",
              }}
              whileHover={{ scale: 1.05 }}
              whileTap={{ scale: 0.96 }}
              data-hover
            >
              {active === link && (
                <motion.span
                  className="absolute inset-0 rounded-xl"
                  style={{ background: "rgba(79,142,247,0.1)" }}
                  layoutId="nav-pill"
                  transition={{ type: "spring", stiffness: 380, damping: 30 }}
                />
              )}
              {link}
            </motion.button>
          ))}
        </div>

        {/* Right */}
        <div className="flex items-center gap-3">
          <PremiumToggle theme={theme} onToggle={onToggleTheme} />

          <MagneticButton as="a">
            <motion.a
              href="#"
              className="hidden md:flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold text-white"
              style={{
                background: "linear-gradient(135deg, #4f8ef7, #7c3aed)",
                boxShadow: "0 4px 15px rgba(79,142,247,0.35)",
                fontFamily: "'Inter', sans-serif",
              }}
              whileHover={{ scale: 1.04, boxShadow: "0 6px 22px rgba(79,142,247,0.55)" }}
              whileTap={{ scale: 0.97 }}
              data-hover
            >
              Resume <FiExternalLink size={13} />
            </motion.a>
          </MagneticButton>

          <motion.button
            className="md:hidden p-2 rounded-xl"
            style={{ background: "rgba(79,142,247,0.1)", border: "1px solid rgba(79,142,247,0.2)" }}
            onClick={() => setMenuOpen((m) => !m)}
            whileTap={{ scale: 0.92 }}
            data-hover
          >
            {menuOpen ? <FiX size={18} color="#4f8ef7" /> : <FiMenu size={18} color="#4f8ef7" />}
          </motion.button>
        </div>
      </motion.div>

      {/* Mobile menu */}
      <AnimatePresence>
        {menuOpen && (
          <motion.div
            className="absolute top-20 left-4 right-4 rounded-2xl p-4 flex flex-col gap-1"
            style={navGlass[theme]}
            initial={{ opacity: 0, y: -10, scale: 0.96 }}
            animate={{ opacity: 1, y: 0, scale: 1 }}
            exit={{ opacity: 0, y: -10, scale: 0.96 }}
            transition={{ duration: 0.22 }}
          >
            {NAV_LINKS.map((link) => (
              <button
                key={link}
                onClick={() => scrollTo(link)}
                className="text-left px-4 py-3 rounded-xl text-sm font-medium"
                style={{
                  color: active === link ? "#4f8ef7" : isDark ? "rgba(232,238,255,0.8)" : "rgba(10,14,26,0.7)",
                  background: active === link ? "rgba(79,142,247,0.1)" : "transparent",
                  fontFamily: "'Inter', sans-serif",
                }}
              >
                {link}
              </button>
            ))}
          </motion.div>
        )}
      </AnimatePresence>
    </motion.nav>
  );
}

// ─── Scroll Progress ──────────────────────────────────────────────────────────
function ScrollProgress() {
  const [p, setP] = useState(0);
  useEffect(() => {
    const fn = () => {
      const el = document.documentElement;
      setP(el.scrollTop / (el.scrollHeight - el.clientHeight));
    };
    window.addEventListener("scroll", fn, { passive: true });
    return () => window.removeEventListener("scroll", fn);
  }, []);
  return (
    <div className="fixed top-0 left-0 right-0 h-0.5 z-[100]" style={{ background: "rgba(79,142,247,0.1)" }}>
      <motion.div
        className="h-full origin-left"
        style={{
          scaleX: p,
          background: "linear-gradient(90deg, #4f8ef7, #7c3aed, #00d4ff)",
          boxShadow: "0 0 8px rgba(79,142,247,0.6)",
        }}
      />
    </div>
  );
}

// ─── Hero ─────────────────────────────────────────────────────────────────────
function Hero({ theme }: { theme: Theme }) {
  const containerRef = useRef<HTMLDivElement>(null);
  const [scrollY, setScrollY] = useState(0);
  const [mouse, setMouse] = useState({ x: 0, y: 0 });

  useEffect(() => {
    const fn = () => setScrollY(window.scrollY);
    window.addEventListener("scroll", fn, { passive: true });
    return () => window.removeEventListener("scroll", fn);
  }, []);

  const handleMouseMove = useCallback((e: React.MouseEvent) => {
    const rect = e.currentTarget.getBoundingClientRect();
    setMouse({
      x: (e.clientX - rect.left - rect.width / 2) / rect.width,
      y: (e.clientY - rect.top - rect.height / 2) / rect.height,
    });
  }, []);

  const typed = useTypingEffect([
    "Senior Frontend Developer",
    "UI/UX Designer",
    "React Architect",
    "Design Systems Engineer",
    "Creative Technologist",
  ]);

  const isDark = theme === "dark";
  const py = scrollY * 0.45;
  const opac = Math.max(0, 1 - scrollY / 700);

  return (
    <section
      id="home"
      ref={containerRef}
      className="relative min-h-screen flex items-center justify-center overflow-hidden"
      onMouseMove={handleMouseMove}
      style={{
        background: isDark
          ? "linear-gradient(135deg, #050816 0%, #0b1020 40%, #0d0a1f 100%)"
          : "linear-gradient(135deg, #e8f0ff 0%, #f0f4ff 50%, #eef0ff 100%)",
      }}
    >
      {/* Orbs */}
      <Orb color="#4f8ef7" size={620} x="-12%" y="-22%" delay={0} />
      <Orb color="#7c3aed" size={520} x="58%" y="28%" delay={2} />
      <Orb color="#00d4ff" size={420} x="28%" y="58%" delay={4} />
      <Orb color="#4f8ef7" size={320} x="82%" y="-8%" delay={1} />

      {/* Grid */}
      <div
        className="absolute inset-0 pointer-events-none"
        style={{
          backgroundImage: `linear-gradient(rgba(79,142,247,${isDark ? "0.04" : "0.07"}) 1px, transparent 1px), linear-gradient(90deg, rgba(79,142,247,${isDark ? "0.04" : "0.07"}) 1px, transparent 1px)`,
          backgroundSize: "60px 60px",
        }}
      />

      {/* Noise */}
      <div
        className="absolute inset-0 opacity-20 pointer-events-none"
        style={{
          backgroundImage: `url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E")`,
          backgroundSize: "150px",
        }}
      />

      <Particles theme={theme} />

      {/* Content */}
      <div
        className="relative z-10 text-center px-6 max-w-5xl mx-auto"
        style={{ transform: `translateY(${py}px)`, opacity: opac }}
      >
        {/* Badge */}
        <motion.div
          className="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8 text-sm font-medium"
          style={{ ...glass[theme], color: isDark ? "rgba(232,238,255,0.8)" : "rgba(10,14,26,0.7)", fontFamily: "'Inter', sans-serif" }}
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.6 }}
        >
          <motion.span
            className="w-2 h-2 rounded-full bg-green-400"
            animate={{ scale: [1, 1.3, 1], opacity: [1, 0.6, 1] }}
            transition={{ duration: 1.8, repeat: Infinity }}
          />
          Available for new opportunities
        </motion.div>

        {/* ANIKET Logo — hero size */}
        <motion.div
          className="mb-4 flex justify-center"
          style={{ transform: `translate(${mouse.x * -16}px, ${mouse.y * -10}px)`, transition: "transform 0.1s ease-out" }}
          initial={{ opacity: 0, y: 40, scale: 0.9 }}
          animate={{ opacity: 1, y: 0, scale: 1 }}
          transition={{ duration: 1.0, delay: 0.2, ease: [0.16, 1, 0.3, 1] }}
        >
          <AniketSVGLogo variant="full" theme={theme} />
        </motion.div>

        {/* Typed role */}
        <motion.div
          className="text-xl md:text-2xl font-semibold mb-6 h-10 flex items-center justify-center gap-2"
          style={{ fontFamily: "'Plus Jakarta Sans', sans-serif", color: isDark ? "rgba(232,238,255,0.6)" : "rgba(10,14,26,0.5)" }}
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.7, delay: 0.4 }}
        >
          <span style={{ color: "#4f8ef7" }}>&lt;</span>
          <span style={{ color: isDark ? "#e8eeff" : "#0a0e1a" }}>{typed}</span>
          <motion.span
            className="w-0.5 h-7 bg-blue-400 rounded-full"
            animate={{ opacity: [1, 0, 1] }}
            transition={{ duration: 0.9, repeat: Infinity }}
          />
          <span style={{ color: "#4f8ef7" }}>/&gt;</span>
        </motion.div>

        {/* Subheadline */}
        <motion.p
          className="text-base md:text-lg max-w-2xl mx-auto mb-10 leading-relaxed"
          style={{ fontFamily: "'Inter', sans-serif", color: isDark ? "rgba(232,238,255,0.5)" : "rgba(10,14,26,0.5)" }}
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.7, delay: 0.5 }}
        >
          8+ years crafting premium digital experiences. I bridge the gap between design and engineering — building interfaces that are as beautiful as they are fast.
        </motion.p>

        {/* CTAs */}
        <motion.div
          className="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16"
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.7, delay: 0.65 }}
        >
          <MagneticButton>
            <motion.button
              onClick={() => document.getElementById("projects")?.scrollIntoView({ behavior: "smooth" })}
              className="flex items-center gap-2 px-7 py-3.5 rounded-2xl text-white font-semibold text-base"
              style={{
                background: "linear-gradient(135deg, #4f8ef7 0%, #7c3aed 100%)",
                boxShadow: "0 4px 24px rgba(79,142,247,0.45), 0 0 0 1px rgba(79,142,247,0.2)",
                fontFamily: "'Inter', sans-serif",
              }}
              whileHover={{ scale: 1.04, boxShadow: "0 8px 32px rgba(79,142,247,0.65)" }}
              whileTap={{ scale: 0.97 }}
              data-hover
            >
              View Work <FiArrowUp style={{ transform: "rotate(45deg)" }} size={16} />
            </motion.button>
          </MagneticButton>

          <MagneticButton>
            <motion.button
              onClick={() => document.getElementById("contact")?.scrollIntoView({ behavior: "smooth" })}
              className="flex items-center gap-2 px-7 py-3.5 rounded-2xl font-semibold text-base"
              style={{
                ...glass[theme],
                color: isDark ? "#e8eeff" : "#0a0e1a",
                fontFamily: "'Inter', sans-serif",
              }}
              whileHover={{ scale: 1.04 }}
              whileTap={{ scale: 0.97 }}
              data-hover
            >
              Let&apos;s Talk <FiMail size={16} />
            </motion.button>
          </MagneticButton>
        </motion.div>

        {/* Stats */}
        <motion.div
          className="flex flex-wrap items-center justify-center"
          initial={{ opacity: 0, y: 30 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.8, delay: 0.8 }}
        >
          {STATS.map((s, i) => (
            <div key={s.label} className="px-8 py-4 text-center" style={{ borderRight: i < STATS.length - 1 ? "1px solid rgba(79,142,247,0.15)" : "none" }}>
              <div
                className="text-2xl md:text-3xl font-bold"
                style={{
                  fontFamily: "'Plus Jakarta Sans', sans-serif",
                  background: "linear-gradient(135deg, #4f8ef7, #00d4ff)",
                  WebkitBackgroundClip: "text",
                  WebkitTextFillColor: "transparent",
                  backgroundClip: "text",
                }}
              >
                {s.value}{s.suffix}
              </div>
              <div className="text-xs mt-1" style={{ color: isDark ? "rgba(232,238,255,0.4)" : "rgba(10,14,26,0.4)", fontFamily: "'Inter', sans-serif" }}>
                {s.label}
              </div>
            </div>
          ))}
        </motion.div>
      </div>

      {/* Scroll indicator */}
      <motion.div
        className="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2"
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        transition={{ delay: 1.8 }}
        style={{ opacity: opac }}
      >
        <span className="text-xs tracking-widest uppercase" style={{ color: isDark ? "rgba(232,238,255,0.3)" : "rgba(10,14,26,0.35)", fontFamily: "'Inter', sans-serif" }}>Scroll</span>
        <motion.div animate={{ y: [0, 8, 0] }} transition={{ duration: 1.6, repeat: Infinity }}>
          <FiChevronDown size={18} color={isDark ? "rgba(232,238,255,0.3)" : "rgba(10,14,26,0.35)"} />
        </motion.div>
      </motion.div>
    </section>
  );
}

